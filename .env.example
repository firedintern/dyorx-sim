# Anthropic API Key (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model selection (default: Claude Haiku 4.5)
LLM_MODEL_NAME=claude-haiku-4-5-20251001

# Alternative models:
# LLM_MODEL_NAME=claude-haiku-4-5-20251001   # Fastest & cheapest (recommended)
# LLM_MODEL_NAME=claude-sonnet-4-6            # Smarter, more expensive
# LLM_MODEL_NAME=claude-opus-4-6              # Most capable, most expensive
